---
export interface Props {
  title?: string;
  demo: string;
}

const { title, demo } = Astro.props;
---

<div class="wasm-demo-wrapper">
  <div id={`wasm-demo-${demo}`} class="wasm-demo-container"></div>
</div>

<script>
  import { crearSimulador } from './demos/paquete-sim';

  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('wasm-demo-paquete-sim');
    if (container) crearSimulador(container);
  });
</script>

<style>
  .wasm-demo-wrapper {
    margin: 1.5rem 0;
  }
  .wasm-demo-container :global(.sim-card) {
    background: linear-gradient(135deg, #0a1e30 0%, #152d48 100%);
    border: 1px solid rgba(37, 99, 235, 0.2);
    border-radius: 12px;
    padding: 1.25rem;
    color: #e2e8f0;
  }
  .wasm-demo-container :global(.sim-header) {
    margin-bottom: 1rem;
  }
  .wasm-demo-container :global(.sim-badge) {
    display: inline-block;
    background: linear-gradient(135deg, #2563eb, #4ecdc4);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 1rem;
    letter-spacing: 0.02em;
  }
  .wasm-demo-container :global(.sim-sub) {
    display: block;
    font-size: 0.75rem;
    color: #94a3b8;
    margin-top: 0.3rem;
  }
  .wasm-demo-container :global(.sim-topology) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin: 1rem 0;
    flex-wrap: wrap;
  }
  .wasm-demo-container :global(.sim-node) {
    text-align: center;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    background: rgba(255,255,255,0.06);
    border: 2px solid transparent;
    transition: all 0.3s ease;
    min-width: 90px;
  }
  .wasm-demo-container :global(.sim-node.active) {
    border-color: #4ecdc4;
    background: rgba(78, 205, 196, 0.1);
    box-shadow: 0 0 20px rgba(78, 205, 196, 0.2);
    transform: scale(1.05);
  }
  .wasm-demo-container :global(.sim-node-icon) {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }
  .wasm-demo-container :global(.sim-node-label) {
    font-size: 0.7rem;
    font-weight: 600;
    color: #cbd5e1;
  }
  .wasm-demo-container :global(.sim-node-label small) {
    font-weight: 400;
    font-size: 0.6rem;
    color: #64748b;
  }
  .wasm-demo-container :global(.sim-arrow) {
    font-size: 1.2rem;
    color: #475569;
  }
  .wasm-demo-container :global(.sim-controls) {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin: 1rem 0;
  }
  .wasm-demo-container :global(.sim-btn) {
    padding: 0.5rem 1.25rem;
    border: none;
    border-radius: 2rem;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    background: linear-gradient(135deg, #2563eb, #3b82f6);
    color: #fff;
    transition: all 0.2s ease;
  }
  .wasm-demo-container :global(.sim-btn:hover:not(:disabled)) {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(37, 99, 235, 0.4);
  }
  .wasm-demo-container :global(.sim-btn:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .wasm-demo-container :global(.sim-btn-secondary) {
    background: rgba(255,255,255,0.1);
    color: #e2e8f0;
  }
  .wasm-demo-container :global(.sim-btn-secondary:hover) {
    background: rgba(255,255,255,0.15);
  }
  .wasm-demo-container :global(.sim-log) {
    max-height: 300px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .wasm-demo-container :global(.sim-step) {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    padding: 0.4rem 0.6rem;
    border-radius: 6px;
    background: rgba(255,255,255,0.04);
    animation: simFadeIn 0.3s ease;
  }
  @keyframes simFadeIn {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .wasm-demo-container :global(.sim-step-icon) {
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
  .wasm-demo-container :global(.sim-step-text) {
    font-size: 0.8rem;
    line-height: 1.4;
    color: #e2e8f0;
  }
  .wasm-demo-container :global(.sim-step-detail) {
    font-size: 0.7rem;
    color: #64748b;
    margin-top: 0.15rem;
    font-style: italic;
  }
  .wasm-demo-container :global(.sim-log::-webkit-scrollbar) {
    width: 4px;
  }
  .wasm-demo-container :global(.sim-log::-webkit-scrollbar-thumb) {
    background: #475569;
    border-radius: 4px;
  }
</style>
