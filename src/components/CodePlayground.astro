---
export interface Props {
  title?: string;
  language?: string;
  code: string;
}

const { title = '▶️ Code Playground', language = 'javascript', code } = Astro.props;
const id = `playground-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="playground" id={id}>
  <div class="playground-header">
    <span class="playground-title">{title}</span>
    <span class="playground-lang">{language}</span>
  </div>
  <textarea class="playground-editor" spellcheck="false">{code}</textarea>
  <div class="playground-toolbar">
    <button class="playground-run">▶️ Ejecutar</button>
    <button class="playground-reset" style="display:none">🔄 Reiniciar</button>
  </div>
  <div class="playground-output" style="display:none">
    <div class="playground-output-header">📤 Salida</div>
    <pre class="playground-output-content"></pre>
  </div>
</div>

<script>
  (() => {
    const el = document.getElementById('{id}');
    if (!el) return;
    const editor = el.querySelector('.playground-editor');
    const runBtn = el.querySelector('.playground-run');
    const resetBtn = el.querySelector('.playground-reset');
    const output = el.querySelector('.playground-output');
    const outputContent = el.querySelector('.playground-output-content');

    let originalCode = editor.value;

    // Simple line-numbered display via CSS
    editor.style.setProperty('--lines', String(editor.value.split('\\n').length));

    editor.addEventListener('input', () => {
      editor.style.setProperty('--lines', String(editor.value.split('\\n').length));
    });

    runBtn.addEventListener('click', () => {
      output.style.display = 'block';
      outputContent.textContent = '';
      const logs = [];
      const fakeConsole = {
        log: (...args) => logs.push(args.map(a => typeof a === 'object' ? JSON.stringify(a, null, 2) : String(a)).join(' ')),
        warn: (...args) => logs.push('⚠️ ' + args.map(a => String(a)).join(' ')),
        error: (...args) => logs.push('❌ ' + args.map(a => String(a)).join(' ')),
      };

      try {
        const fn = new Function('console', editor.value);
        const result = fn(fakeConsole);
        if (result !== undefined) logs.push('→ ' + JSON.stringify(result, null, 2));
        outputContent.textContent = logs.join('\\n') || '✓ Ejecutado (sin salida)';
        outputContent.className = 'playground-output-content';
      } catch (e) {
        outputContent.textContent = '❌ Error: ' + e.message;
        outputContent.className = 'playground-output-content playground-output-error';
      }

      runBtn.style.display = 'none';
      resetBtn.style.display = 'inline-flex';
    });

    resetBtn.addEventListener('click', () => {
      editor.value = originalCode;
      editor.style.setProperty('--lines', String(originalCode.split('\\n').length));
      output.style.display = 'none';
      outputContent.textContent = '';
      runBtn.style.display = 'inline-flex';
      resetBtn.style.display = 'none';
    });
  })();
</script>

<style>
  .playground {
    margin: 1.5rem 0;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(37, 99, 235, 0.2);
    background: #0d1117;
  }
  .playground-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: #161b22;
    border-bottom: 1px solid #30363d;
  }
  .playground-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: #c9d1d9;
  }
  .playground-lang {
    font-size: 0.65rem;
    font-weight: 600;
    color: #8b949e;
    background: #21262d;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
  }
  .playground-editor {
    width: 100%;
    min-height: 200px;
    padding: 0.75rem;
    font-family: 'JetBrains Mono', 'Consolas', 'Courier New', monospace;
    font-size: 0.78rem;
    line-height: 1.55;
    color: #c9d1d9;
    background: #0d1117;
    border: none;
    outline: none;
    resize: vertical;
    tab-size: 2;
    white-space: pre;
    overflow-x: auto;
  }
  .playground-editor:focus {
    box-shadow: inset 0 0 0 1px #2563eb;
  }
  .playground-toolbar {
    display: flex;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    background: #161b22;
    border-top: 1px solid #30363d;
  }
  .playground-run {
    padding: 0.4rem 1rem;
    border: none;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    background: #238636;
    color: #fff;
    transition: all 0.2s ease;
  }
  .playground-run:hover {
    background: #2ea043;
  }
  .playground-reset {
    padding: 0.4rem 1rem;
    border: 1px solid #30363d;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    background: transparent;
    color: #c9d1d9;
    transition: all 0.2s ease;
  }
  .playground-reset:hover {
    background: #21262d;
  }
  .playground-output {
    border-top: 1px solid #30363d;
  }
  .playground-output-header {
    font-size: 0.65rem;
    font-weight: 700;
    color: #8b949e;
    padding: 0.35rem 0.75rem;
    background: #161b22;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .playground-output-content {
    padding: 0.75rem;
    margin: 0;
    font-family: 'JetBrains Mono', 'Consolas', 'Courier New', monospace;
    font-size: 0.75rem;
    line-height: 1.5;
    color: #7ee787;
    background: #0d1117;
    white-space: pre-wrap;
    word-break: break-all;
    max-height: 300px;
    overflow-y: auto;
  }
  .playground-output-error {
    color: #f85149;
  }
</style>
